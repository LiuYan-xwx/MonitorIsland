<abstractions:MonitorProviderControlBase
    x:Class="MonitorIsland.Controls.MonitorProviderSettingsControls.SensorSettingsControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:abstractions="using:MonitorIsland.Abstractions"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonitorIsland.Controls.MonitorProviderSettingsControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:MonitorIsland.Models"
    xmlns:providersettings="clr-namespace:MonitorIsland.Models.MonitorProviderSettings"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:TypeArguments="providersettings:SensorMonitorSettings"
    Loaded="MonitorProviderControlBase_Loaded"
    mc:Ignorable="d">
    <StackPanel DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:SensorSettingsControl}}">
        <controls:SettingsExpander
            Description="选择要监控的硬件传感器"
            Header="传感器"
            IconSource="{ci:FluentIconSource &#xF1B4;}">
            <controls:SettingsExpander.Footer>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        x:Name="SelectedSensorText"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <Button Command="{Binding SelectSensorCommand}" Content="选择传感器" />
                    <controls:ProgressRing
                        Width="24"
                        Height="24"
                        IsActive="{Binding SelectSensorCommand.IsRunning}" />
                </StackPanel>
            </controls:SettingsExpander.Footer>
        </controls:SettingsExpander>
    </StackPanel>

</abstractions:MonitorProviderControlBase>
